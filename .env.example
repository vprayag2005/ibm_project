# ============================================================
#  IBM Watsonx.ai — Nutrition Agent  |  Environment Variables
#  ──────────────────────────────────────────────────────────
#  HOW TO USE:
#    1. Copy this file:  cp .env.example .env
#    2. Fill in your real values in .env
#    3. NEVER commit .env to Git  (.gitignore already covers it)
# ============================================================


# ── IBM CLOUD CREDENTIALS (required) ────────────────────────
#
# IBM Cloud API Key
#   • Go to: https://cloud.ibm.com/iam/apikeys
#   • Click "Create an IBM Cloud API key"
#   • Copy the key immediately (shown only once)
#
IBM_API_KEY=your_ibm_cloud_api_key_here

# IBM Watsonx.ai Project ID
#   • Go to: https://dataplatform.cloud.ibm.com/
#   • Open your project → Manage tab → General
#   • Copy the "Project ID" (UUID format)
#
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# IBM Watsonx.ai Service URL
#   Dallas (default) : https://us-south.ml.cloud.ibm.com
#   Frankfurt        : https://eu-de.ml.cloud.ibm.com
#   Tokyo            : https://jp-tok.ml.cloud.ibm.com
#   London           : https://eu-gb.ml.cloud.ibm.com
#
WATSONX_URL=https://us-south.ml.cloud.ibm.com


# ── FLASK SETTINGS ───────────────────────────────────────────
#
# Secret key used to sign session cookies.
# Generate a strong random value for production, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
FLASK_SECRET_KEY=change_me_to_a_random_secret_key_in_production

# Environment mode: development | production
FLASK_ENV=development

# Enable Flask debug mode: True | False
# Set to False in production!
FLASK_DEBUG=True

# Port the server listens on
PORT=5000
